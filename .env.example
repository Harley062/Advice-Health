# Backend
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL (prioritário, recomendado para Render)
# Exemplo: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Database
DB_HOST=db
DB_NAME=todoapp
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432
DB_SSLMODE=prefer

# CORS (only needed when DEBUG=False)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:8000/api
